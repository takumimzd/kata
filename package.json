{
  "name": "kata",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "description": "型 — 個人開発向けの汎用デザインシステム",
  "//sideEffects": "JS は副作用なし (積極的に tree-shake)、CSS は到達したものだけ保持する",
  "sideEffects": ["**/*.css"],
  "scripts": {
    "dev": "vite dev --port 3100",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": "./src/ds/index.ts",
    "./styles.css": "./src/ds/styles/index.css",
    "./tokens.css": "./src/ds/styles/index.css"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "dependencies": {
    "@lexical/list": "^0.45.0",
    "@lexical/markdown": "^0.45.0",
    "@lexical/react": "^0.45.0",
    "@lexical/rich-text": "^0.45.0",
    "@lexical/selection": "^0.45.0",
    "@lexical/utils": "^0.45.0",
    "lexical": "^0.45.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.1",
    "@cloudflare/workers-types": "^4.20260611.1",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-start": "^1.168.25",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.0",
    "vite": "^8.0.16",
    "wrangler": "^4.99.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "workerd", "sharp"]
  }
}
